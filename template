# Template file for 'yabridge-git'
pkgname=yabridge-git
version=48ea9749b682c48875366134a42073d6b3d0a8c4
revision=1
archs="x86_64"
hostmakedepends="cargo pkg-config wine-tools wine-devel libxcb-devel meson ninja cmake git dbus-devel"
short_desc="Modern way to use Windows VST2, VST3 and CLAP plugins on Linux"
license="GPL-3.0-or-later"
homepage="https://github.com/robbert-vdh/yabridge"
distfiles="https://github.com/robbert-vdh/yabridge/archive/${version}.zip"
checksum="36ab1c4bdd5808d024ec2bed1a775ab47e5b61f71ebb0bfb77e1c737fa61873f"

do_configure() {
    meson setup build --buildtype=release --cross-file=cross-wine.conf --unity=on --unity-size=1000
}

do_build() {
    ninja -C build
    (cd tools/yabridgectl; cargo build --release --locked --all-features --target-dir=target)
}

do_install() {
    vmkdir usr/bin
    for f in ${wrksrc}/build/yabridge-host.exe{,.so}; do
        vbin $f
    done
    vbin ${wrksrc}/tools/yabridgectl/target/release/yabridgectl
    vmkdir usr/lib
    for f in ${wrksrc}/build/libyabridge{,-chainloader}-{vst2,vst3,clap}.so; do
        vcopy $f usr/lib
    done
}
